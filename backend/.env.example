# System Configuration Template
ENVIRONMENT=development
DEV_OTP_ENABLED=true

# Database Settings
DATABASE_URL=postgresql://ayushiranjan@localhost/chatbot
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# JWT Auth parameters
JWT_SECRET_KEY=yoursecretkey
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SMTP parameters
SMTP_EMAIL=placeholder@gmail.com
SMTP_APP_PASSWORD=placeholder_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Data Retention Periods (in days)
RETENTION_RATE_LIMITS_DAYS=1
RETENTION_OTP_EXPIRED_DAYS=1
RETENTION_METRICS_DAYS=90
RETENTION_QUERY_LOGS_DAYS=180
